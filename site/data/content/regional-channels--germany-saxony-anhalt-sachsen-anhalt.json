20193/e3f815bb3b6b270deddcb6aa58230a58.png?size=512", "timestamp": "Saturday, March 28, 2026 6:59 a.m.", "timestamp_short": "2026-03-28 6:59 a.m.", "text": "ich bin genau zwischen Magdeburg und leipzig und ich scheine hier aus dem Loch gar keine Verbindung aufbauen zu können. selbst auf dem Dachboden finde ich keine Knoten", "content_html": "<div class=\"chatlog__content chatlog__markdown\"><span class=chatlog__markdown-preserve>ich bin genau zwischen Magdeburg und leipzig und ich scheine hier aus dem Loch gar keine Verbindung aufbauen zu k&#246;nnen. selbst auf dem Dachboden finde ich keine Knoten <img\n    loading=\"lazy\"\n    class=\"chatlog__emoji \"\n    alt=\"😩\"\n    title=\"weary\"\n    src=\"https://cdn.jsdelivr.net/gh/twitter/twemoji@latest/assets/svg/1f629.svg\"></span></div>", "embeds_html": [], "attachments_html": [], "reactions_html": "", "reply_html": "", "forwarded_html": ""}, {"id": "1487420985987829961", "author": "Deadpool", "author_handle": "destotelhorus", "user_id": "345682527370870815", "avatar": "https://cdn.discordapp.com/avatars/345682527370870815/72b4fa52675ac4bc608a59da621ce9ac.png?size=512", "timestamp": "Saturday, March 28, 2026 7:59 a.m.", "timestamp_short": "2026-03-28 7:59 a.m.", "text": "Dreist", "content_html": "<div class=\"chatlog__content chatlog__markdown\"><span class=chatlog__markdown-preserve>Dreist <img\n    loading=\"lazy\"\n    class=\"chatlog__emoji \"\n    alt=\"😕\"\n    title=\"confused\"\n    src=\"https://cdn.jsdelivr.net/gh/twitter/twemoji@latest/assets/svg/1f615.svg\"></span></div>", "embeds_html": [], "attachments_html": [], "reactions_html": "", "reply_html": "", "forwarded_html": ""}, {"id": "1487572792135254077", "author": "mouse ▒ (ghosts)", "author_handle": "a.l.i.n.a", "user_id": "221388208909320193", "avatar": "https://cdn.discordapp.com/avatars/221388208909320193/e3f815bb3b6b270deddcb6aa58230a58.png?size=512", "timestamp": "Saturday, March 28, 2026 6:03 p.m.", "timestamp_short": "2026-03-28 6:03 p.m.", "t