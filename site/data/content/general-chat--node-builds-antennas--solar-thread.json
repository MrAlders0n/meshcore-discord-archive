c=\"https://cdn.discordapp.com/attachments/1432436201930887309/1432508893304455330/20251007_155403.jpg?ex=69ebfa5e&amp;is=69eaa8de&amp;hm=d67ad83488c064c25b286aa890925a5f91caf9ea906232bf990b92d171c9cefa&amp;\" alt=\"Image attachment\" title=\"Image: 20251007_155403.jpg (188.26 KB)\" loading=lazy> </a></div>"], "reactions_html": "<div class=chatlog__reactions><div class=chatlog__reaction title=bird><img class=\"chatlog__emoji chatlog__emoji--small\" alt=🐦 src=https://cdn.jsdelivr.net/gh/twitter/twemoji@latest/assets/svg/1f426.svg loading=lazy> <span class=chatlog__reaction-count>1</span></div><div class=chatlog__reaction title=clap><img class=\"chatlog__emoji chatlog__emoji--small\" alt=👏 src=https://cdn.jsdelivr.net/gh/twitter/twemoji@latest/assets/svg/1f44f.svg loading=lazy> <span class=chatlog__reaction-count>1</span></div></div>", "reply_html": "", "forwarded_html": ""}, {"id": "1432655849943339028", "author": "silverphish 🌈", "author_handle": "silverphish", "user_id": "279373208556142592", "avatar": "https://cdn.discordapp.com/avatars/279373208556142592/d78c323b2041a7259b7477ffe3701f3e.png?size=512", "timestamp": "Tuesday, October 28, 2025 5:02 a.m.", "timestamp_short": "2025-10-28 5:02 a.m.", "text": "Yup, visibility is a big reason. I want this to be a guerrilla repeater and keep it inconspicuous", "content_html": "<div class=\"chatlog__content chatlog__markdown\"><span class=chatlog__markdown-preserve>Yup, visibility is a big reason. I want this to be a guerrilla repeater and keep it inconspicuous</span></div>", "embeds_html": [], "attachments_html": [], "reactions_html": "<div class=chatlog__reactions><div class=chatlog__reaction title=thumbsup><img class=\"chatlog__emoji chatlog__emoji--small\" alt=👍 src=https://cdn.jsdelivr.net/gh/twitter/twemoji@latest/assets/svg/1f44d.svg loading=lazy> <span class=chatlog__reaction-count>2</span></div></div>", "reply_html": "<div class=chatlog__reply><img class=chatlog__reply-avatar src=\"https://cdn.discordapp.com/avatars/1001187579221254155/5093cda953085e66201d8a617dc03e77.png?size=512\" alt=Avatar loading=lazy><div class=chatlog__reply-author style=color:rgb(31,139,76) title=mikesallotment>Mike&#x27;s Allotment</div><div class=chatlog__reply-content><span class=chatlog__reply-link onclick=\"scrollToMessage(event,'1432654462614376458')\"> Very nice <img\n    loading=\"lazy\"\n    class=\"chatlog__emoji \"\n    alt=\"👏\"\n    title=\"clap\"\n    src=\"https://cdn.jsdelivr.net/gh/twitter/twemoji@latest/assets/svg/1f44f.svg\"> Out of interest - wondering why you decided to install the antenna inside rather than external? Purely from a security visibility point of view perhaps? </span></div></div>", "forwarded_html": ""}, {"id": "1432669321905049693", "author": "silverphish 🌈", "author_handle": "silverphish", "user_id": "279373208556142592", "avatar": "https://cdn.discordapp.com/avatars/279373208556142592/d78c323b2041a7259b7477ffe3701f3e.png?size=512", "timestamp": "Tuesday, October 28, 2025 5:56 a.m.", "timestamp_short": "2025-10-28 5:56 a.m.", "text": "Does anyone know where to get historical weather data for solar radiation? I've noticed accuweather provide the WH/m2/d behind their paid API, but Im wondering if theres anywhere else that offers the same data (or higher quality)", "content_html": "<div class=\"chatlog__content chatlog__markdown\"><span class=chatlog__markdown-preserve>Does anyone know where to get historical weather data for solar radiation? I&#39;ve noticed accuweather provide the WH/m2/d behind their paid API, but Im wondering if theres anywhere else that offers the same data (or higher quality)</span></div>", "embeds_html": [], "attachments_html": [], "reactions_html": "", "reply_html": "", "forwarded_html": ""}, {"id": "1432673416116179014", "author": "mowcius", "author_handle": "mowcius", "user_id": "222799443890536449", "avatar": "https://cdn.discordapp.com/avatars/222799443890536449/cb67ead0dcf8375d5a198a3b1d573884.png?size=512", "timestamp": "Tuesday, October 28, 2025 6:12 a.m.", "timestamp_short": "2025-10-28 6:12 a.m.", "text": "I've always struggled with historical climate/weather data in general and decided some time ago that as much as possible I'd just collect it myself.", "content_html": "<div class=\"chatlog__content chatlog__markdown\"><span class=chatlog__markdown-preserve>I&#39;ve always struggled with historical climate/weather data in general and decided some time ago that as much as possible I&#39;d just collect it myself.</span></div>", "embeds_html": [], "attachments_html": [], "reactions_html": "", "reply_html": "", "forwarded_html": ""}, {"id": "1435605009978101880", "author": "silverphish 🌈", "author_handle": "silverphish", "user_id": "279373208556142592", "avatar": "https://cdn.discordapp.com/avatars/279373208556142592/d78c323b2041a7259b7477ffe3701f3e.png?size=512", "timestamp": "Wednesday, November 5, 2025 7:21 a.m.", "timestamp_short": "2025-11-05 7:21 a.m.", "text": "A note about Adafruit solar charger", "content_html": "<div class=\"chatlog__content chatlog__markdown\"><span class=chatlog__markdown-preserve>A note about Adafruit solar charger</span></div>", "embeds_html": [], "attachments_html": [], "reactions_html": "", "reply_html": "", "forwarded_html": ""}, {"id": "1435685538068955292", "author": "Ceres Station 🌑", "author_handle": "82a6_31995", "user_id": "1416146698115485798", "avatar": "", "timestamp": "Wednesday, November 5, 2025 12:41 p.m.", "timestamp_short": "2025-11-05 12:41 p.m.", "text": "Interesting", "content_html": "<div class=\"chatlog__content chatlog__markdown\"><span class=chatlog__markdown-preserve>Interesting</span></div>", "embeds_html": [], "attachments_html": [], "reactions_html": "", "reply_html": "", "forwarded_html": ""}]}