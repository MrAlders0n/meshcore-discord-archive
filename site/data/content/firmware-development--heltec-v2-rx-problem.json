, "embeds_html": [], "attachments_html": [], "reactions_html": "", "reply_html": "", "forwarded_html": ""}, {"id": "1476692002924924928", "author": "gjelsoe", "author_handle": "cossie1413", "user_id": "297128333332709377", "avatar": "https://cdn.discordapp.com/avatars/297128333332709377/d677b018cc6072f37763a51d37bb76f1.png?size=512", "timestamp": "Thursday, February 26, 2026 4:26 p.m.", "timestamp_short": "2026-02-26 4:26 p.m.", "text": "No, with : pinMode(21, OUTPUT); digitalWrite(21, LOW)", "content_html": "<div class=\"chatlog__content chatlog__markdown\"><span class=chatlog__markdown-preserve>No, with :\n<code class=\"chatlog__markdown-pre chatlog__markdown-pre--multiline nohighlight\">  pinMode(21, OUTPUT);\n  digitalWrite(21, LOW)</code></span></div>", "embeds_html": [], "attachments_html": [], "reactions_html": "", "reply_html": "", "forwarded_html": ""}, {"id": "1476692397562789909", "author": "powernet", "author_handle": "powernet_60896", "user_id": "1466207904611832063", "avatar": "", "timestamp": "Thursday, February 26, 2026 4:28 p.m.", "timestamp_short": "2026-02-26 4:28 p.m.", "text": "OLED is always powered. It's react to push button", "content_html": "<div class=\"chatlog__content chatlog__markdown\"><span class=chatlog__markdown-preserve>OLED is always powered. It&#39;s react to push button</span></div>", "embeds_html": [], "attachments_html": [], "reactions_html": "", "reply_html": "", "forwarded_html": ""}, {"id": "1476692762492408012", "author": "gjelsoe", "author_handle": "cossie1413", "user_id": "297128333332709377", "avatar": "https://cdn.discordapp.com/avatars/297128333332709377/d677b018cc6072f37763a51d37bb76f1.png?size=512", "timestamp": "Thursday, February 26, 2026 4:29 p.m.", "timestamp_short": "2026-02-26 4:29 p.m.", "text": "Try forcing it LOW anyway", "content_html": "<div class=\"chatlog__content chatlog__markdown\"><span class=chatlog__markdown-preserve>Try forcing it LOW anyway</span></div>", "embeds_html": [], "attachments_html": [],