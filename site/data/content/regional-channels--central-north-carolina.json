{"id": "regional-channels--central-north-carolina", "title": "Central North Carolina", "forum": "regional-channels", "messages": [{"id": "1462961873656746024", "author": "Tofu", "author_handle": "takumidesh", "user_id": "138839428582866944", "avatar": "https://cdn.discordapp.com/avatars/138839428582866944/6ca625a845484e8c158bcff07d5be433.png?size=512", "timestamp": "Monday, January 19, 2026 7:08 p.m.", "timestamp_short": "2026-01-19 7:08 p.m.", "text": "Wanted to create a thread for Charlotte and the Triad. (edited)", "content_html": "<div class=\"chatlog__content chatlog__markdown\"><span class=chatlog__markdown-preserve>Wanted to create a thread for Charlotte and the Triad.</span> <span class=chatlog__edited-timestamp title=\"Monday, January 26, 2026 9:42 a.m.\">(edited)</span></div>", "embeds_html": [], "attachments_html": [], "reactions_html": "", "reply_html": "", "forwarded_html": ""}, {"id": "1466429964953059380", "author": "Josh in NC", "author_handle": "joshtisdale", "user_id": "1069292952767184937", "avatar": "https://cdn.discordapp.com/avatars/1069292952767184937/e94241d38b651df3766ef71857b25f60.png?size=512", "timestamp": "Thursday, January 29, 2026 8:49 a.m.", "timestamp_short": "2026-01-29 8:49 a.m.", "text": "Greetings from Summerfield!", "content_html": "<div class=\"chatlog__content chatlog__markdown\"><span class=chatlog__markdown-preserve>Greetings from Summerfield!</span></div>", "embeds_html": [], "attachments_html": [], "reactions_html": "", "reply_html": "", "forwarded_html": ""}, {"id": "1466663595092742186", "author": "cg2sy", "author_handle": "c_g2sy", "user_id": "583701792660127744", "avatar": "https://cdn.discordapp.com/avatars/583701792660127744/bd6dfc758a6af9d67f72d91fbb75e5e2.png?size=512", "timestamp": "Friday, January 30, 2026 12:17 a.m.", "timestamp_short": "2026-01-30 12:17 a.m.", "text": "Checking in! meshcore://110021b9c13543935ea0d6e3eefe37d7e1669a529ae51cfd40a92a6c7eca23720d8798237b69df604b87312de1a6ccc16b4734013e9ae72d1d98f7ca